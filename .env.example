# Constellus — Environment Variables
# Copy this file to .env and populate values for local development.
# Never commit .env to git.

# ── Core ──────────────────────────────────────────────────────────────────────
SECRETS_PROVIDER=env          # env | azure_keyvault | aws | gcp | hashicorp_vault
DATABASE_URL=postgresql://constellus:constellus@localhost:5432/constellus
SECRET_KEY=                   # generate with: python -c "import secrets; print(secrets.token_hex(32))"
DEBUG=false

# ── Connectors ────────────────────────────────────────────────────────────────

# Cloudflare
CLOUDFLARE_API_TOKEN=

# Wiz
WIZ_CLIENT_ID=
WIZ_CLIENT_SECRET=
WIZ_API_ENDPOINT=

# FortiManager Connector (sidecar)
FORTIMANAGER_CONNECTOR_URL=
FORTIMANAGER_CONNECTOR_API_KEY=

# Tenable
TENABLE_API_KEY=
TENABLE_API_SECRET=

# ── Email ─────────────────────────────────────────────────────────────────────
# Mailtrap (sandbox for dev — inbox_id configured via admin UI)
MAILTRAP_API_TOKEN=
